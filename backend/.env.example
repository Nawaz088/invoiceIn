# InvoiceIN Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# DJANGO SETTINGS
# =============================================================================

# Django Secret Key (generate a new one for production)
DJANGO_SECRET_KEY=your-super-secret-key-here

# Debug Mode (set to False for production)
DEBUG=True

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite (Development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (Production) - Uncomment and fill in for production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=invoicein_db
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# JWT Token Lifetime (in hours for access, days for refresh)
JWT_ACCESS_HOURS=24
JWT_REFRESH_DAYS=7

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Frontend URLs (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=InvoiceIN <noreply@invoicein.com>

# =============================================================================
# PAYMENT GATEWAY - RAZORPAY
# =============================================================================

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# GST API CONFIGURATION
# =============================================================================

# ClearTax, Masters India, or other GST API
GST_API_KEY=your-gst-api-key
GST_API_SECRET=your-gst-api-secret
GST_API_MODE=test

# =============================================================================
# SMS/OTP CONFIGURATION
# =============================================================================

# MSG91, Twilio, or other OTP provider
OTP_PROVIDER_API_KEY=your-otp-provider-api-key

# =============================================================================
# WHATSAPP BUSINESS API
# =============================================================================

# Interakt or Twilio WhatsApp
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=919876543210

# =============================================================================
# FILE STORAGE - AWS S3
# =============================================================================

USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=invoicein-media
AWS_S3_REGION_NAME=ap-south-1

# =============================================================================
# PDF GENERATION
# =============================================================================

PDF_ENGINE=weasyprint

# =============================================================================
# ADDITIONAL SERVICES
# =============================================================================

# SMS Service API Key
SMS_API_KEY=

# Cloud Storage (for backups)
BACKUP_STORAGE=
